{
  "name": "aichat-release-workflow",
  "version": "1.0.0",
  "description": "Reusable GitHub Actions workflow + TypeScript scripts to automate AIChat releases (tag bump, OpenAI release notes, GitHub Release, Slack notification).",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "24.17.0"
  },
  "scripts": {
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit -p .",
    "build-only": "tsup",
    "build": "pnpm type-check && pnpm build-only",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "run:summarize": "node dist/summarize-commits.js",
    "run:notify-slack": "node dist/notify-slack.js"
  },
  "dependencies": {
    "@tryfabric/mack": "^1.2.1",
    "axios": "^1.13.2",
    "he": "^1.2.0",
    "openai": "^6.8.1",
    "simple-git": "^3.30.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/he": "^1.2.3",
    "@types/node": "^24.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
